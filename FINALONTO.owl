<owl:Class rdf:about="http://ffrdc.ebiquity.umbc.edu/ns/ontology#CWE">
  <owl:equivalentClass rdf:resource="http://capec.mitre.org/capec_v1#Weakness"/>
  <rdfs:subClassOf rdf:resource="http://ffrdc.ebiquity.umbc.edu/ns/ontology#UCOThing"/>
</owl:Class>

<owl:Class rdf:about="http://ffrdc.ebiquity.umbc.edu/ns/ontology#Campaign">
  <rdfs:subClassOf rdf:resource="http://ffrdc.ebiquity.umbc.edu/ns/ontology#UCOThing"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="http://ffrdc.ebiquity.umbc.edu/ns/ontology#usesAttacks"/>
      <owl:onClass rdf:resource="http://ffrdc.ebiquity.umbc.edu/ns/ontology#Attack"/>
      <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Campaigns are instances of ThreatActors pursuing an intent, as observed through sets of Incidents and/or TTP, potentially across organizations.

Source: https://stix.mitre.org/about/documents/STIX_Whitepaper_v1.1.pdf</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="http://ffrdc.ebiquity.umbc.edu/ns/ontology#ConfigurationError">
  <rdfs:subClassOf rdf:resource="http://ffrdc.ebiquity.umbc.edu/ns/ontology#Means"/>
