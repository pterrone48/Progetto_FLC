        <owl:Class>
          <owl:unionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="AttackPattern"/>
            <rdf:Description rdf:about="Exploit"/>
            <rdf:Description rdf:about="Malware"/>
          </owl:unionOf>
        </owl:Class>
      </owl:someValuesFrom>
    </owl:Restriction>
  </owl:equivalentClass>
  <rdfs:subClassOf rdf:resource="http://ffrdc.ebiquity.umbc.edu/ns/ontology#MeansOrConsequence"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="http://ffrdc.ebiquity.umbc.edu/ns/ontology#resultsIn"/>
      <owl:someValuesFrom rdf:resource="http://ffrdc.ebiquity.umbc.edu/ns/ontology#Consequence"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

