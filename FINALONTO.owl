         xmlns="http://ffrdc.ebiquity.umbc.edu/ns/ontology/">

<owl:Ontology rdf:about="http://ffrdc.ebiquity.umbc.edu/ns/ontology">
  <owl:versionIRI rdf:resource=""/>
</owl:Ontology>

<owl:ObjectProperty rdf:about="behaviour">
  <rdfs:domain rdf:resource="http://ffrdc.ebiquity.umbc.edu/ns/ontology#TTP"/>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="AttackPattern"/>
        <rdf:Description rdf:about="Exploit"/>
        <rdf:Description rdf:about="Malware"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="hasAffectedSoftware"/>

