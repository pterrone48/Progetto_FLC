<owl:NamedIndividual rdf:about="39c2b71d9b14c510">
  <rdf:type rdf:resource="DDoS"/>
  <onto:isLaunchedBy rdf:resource="Anti_WMD_Team"/>
  <onto:associatedCampaigns rdf:resource="Las_Vegas_Sands_Corp"/>
  <onto:affectsProduct rdf:resource="Accommodation_and_Food_Services"/>
  <onto:isLaunchedBy rdf:resource="Iran__Islamic_Republic_of"/>
  <hasCampaign rdf:resource="Nevada"/>
  <hasEventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2014-02-10T00:00:00.000</hasEventDate>
  <hasYear rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2014</hasYear>
  <hasMonth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</hasMonth>
  <hasActor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anti WMD Team</hasActor>
  <hasActorType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hacktivist</hasActorType>
  <hasOrganization rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Las Vegas Sands Corp</hasOrganization>
  <hasIndustry rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Accommodation and Food Services</hasIndustry>
  <onto:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Political-Espionage</onto:description>
  <hasEventType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mixed</hasEventType>
  <hasEventSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Data Attack,Exploitation of Application Server,Message Manipulation</hasEventSubtype>
  <onto:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Some websites owned by Las Vegas Sands Corp, one of the world's largest casino operators, have been hacked and defaced by a group called the Anti WMD Team. The defaced page also contains personal information of Sands employees including e-mail ID and social security numbers. Additionally, the attackers deployed data-wiping malware on the Sands networks, severely disrupting their operation. The attack was allegedly carried out by Iranian hackers in retaliation for a remark by Sands Corp CEO Sheldon Adelson.</onto:description>
  <hasCountry rdf:datatype="http://www.w3.org/2001/XMLSchema#string">United States of America</hasCountry>
  <hasActorCountry rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Iran (Islamic Republic of)</hasActorCountry>
  <hasState rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nevada</hasState>
  <hasCounty rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clark</hasCounty>
</owl:NamedIndividual>

