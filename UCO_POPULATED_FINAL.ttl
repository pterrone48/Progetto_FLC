        owl:Thing .

ns1:Indicator a owl:Class ;
    rdfs:subClassOf ns2:UCOThing .

ns2:Attacker a owl:Class ;
    rdfs:comment """EquivalentClass: ThreatActor
ThreatActors are characterizations of malicious actors (or adversaries) representing a cyber attack threat including presumed intent and historically observed behavior.

Source: https://stix.mitre.org/about/documents/STIX_Whitepaper_v1.1.pdf"""^^xsd:string ;
    rdfs:subClassOf ns2:UCOThing ;
    owl:equivalentClass ns2:ThreatActor .

ns2:Incident a owl:Class ;
    rdfs:comment """Incidents are discrete instances of Indicators affecting an organization along with information discovered or decided during an incident response investigation.

Source: https://stix.mitre.org/about/documents/STIX_Whitepaper_v1.1.pdf"""^^xsd:string ;
    rdfs:subClassOf ns2:UCOThing .

ns2:Process a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/Category:Process_(computing)"^^xsd:anyURI ;
    rdfs:subClassOf ns2:UCOThing .

ns2:Campaign a owl:Class ;
    rdfs:comment """Campaigns are instances of ThreatActors pursuing an intent, as observed through sets of Incidents and/or TTP, potentially across organizations.

Source: https://stix.mitre.org/about/documents/STIX_Whitepaper_v1.1.pdf"""^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ns2:Attack ;
            owl:onProperty ns2:usesAttacks ],
        ns2:UCOThing .

ns2:CourseofAction a owl:Class ;
    rdfs:comment """CoursesOfAction are specific measures to be taken to address threat whether they are corrective or preventative to address ExploitTargets, or responsive to counter or mitigate the potential impacts of Incidents.

Source: https://stix.mitre.org/about/documents/STIX_Whitepaper_v1.1.pdf"""^^xsd:string ;
    rdfs:subClassOf ns2:UCOThing .

