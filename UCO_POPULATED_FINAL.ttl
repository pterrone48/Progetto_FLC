        owl:Thing .

ns2:Consequence a owl:Class ;
    rdfs:subClassOf ns2:MeansOrConsequence ;
    owl:equivalentClass ns2:Observable .

xsd:string rdfs:comment "Campaigns are instances of ThreatActors pursuing an intent, as observed through sets of Incidents and/or TTP, potentially across organizations."^^xsd:string .

ns1:Turkey a ns2:ThreatActor,
        owl:NamedIndividual .

ns2:Attack a owl:Class ;
    rdfs:comment """An attack (noun) is the use of an exploit(s) by an adversary to take advantage of a weakness(s) with the intent of achieving a negative technical impact(s).

Source: https://capec.mitre.org/about/glossary.html#Attack

From the bove definition, "the use of an exploit(s)" is means, "an adversary" is attacker, and "negative technical impact(s)" is consequence."""^^xsd:string ;
    rdfs:subClassOf ns2:UCOThing ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ns2:Consequence ;
            owl:onProperty ns2:hasConsequence ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ns2:Means ;
            owl:onProperty ns2:hasMeans ],
        ns2:Incident .

ns1:Exploit a owl:Class ;
    rdfs:subClassOf ns2:UCOThing .

ns2:Web a owl:Class ;
    rdfs:subClassOf ns2:Source .

ns2:resultsIn a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:domain ns2:Means ;
    rdfs:range ns2:Consequence .

