    rdfs:domain ns2:Attacker,
        ns2:Campaign,
        ns2:Consequence,
        ns2:CourseofAction,
        ns2:Means,
        ns2:Vulnerability,
        ns1:Indicator ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf ns2:hasVendor .

ns1:hasType a owl:ObjectProperty ;
    rdfs:domain ns2:Attacker ;
    rdfs:range ns1:StatementType .

ns1:hasWeakness a owl:ObjectProperty ;
    rdfs:domain ns2:ExploitTarget ;
    rdfs:range ns2:CWE ;
    rdfs:subPropertyOf owl:topObjectProperty .

ns1:hasYear a owl:DatatypeProperty ;
    rdfs:domain ns2:Incident,
        ns2:UCOThing ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf owl:topDataProperty .

<http://cybox.mitre.org/cybox_v1#Observable> a owl:Class ;
    rdfs:subClassOf ns2:UCOThing ;
    owl:equivalentClass ns2:Observable .

<http://ffrdc.ebiquity.umbc.edu/ns/ontology> a owl:Ontology ;
    owl:versionIRI <http://ffrdc.ebiquity.umbc.edu/ns/ontology> .

ns2:Backdoor a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:RemoteAccess ],
        ns2:MaliciousCodeExecution .

ns2:IDPS a owl:Class ;
    rdfs:subClassOf ns2:Source .

ns2:Logic a owl:Class ;
    rdfs:subClassOf ns2:TriggeredCode .

ns2:MitnickAttack a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/The_Art_of_Intrusion"^^xsd:anyURI ;
    rdfs:subClassOf ns2:Consequence .

ns2:NetFlood a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/describe/?url=http%3A%2F%2Fsw.opencyc.org%2F2008%2F06%2F10%2Fconcept%2Fen%2FTribeFloodNet_DenialOfServiceProgram&sid=7707"^^xsd:anyURI ;
    rdfs:subClassOf ns2:DenialOfService .

ns2:OperatingSystem a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/ontology/operatingSystem"^^xsd:anyURI ;
    rdfs:subClassOf ns2:Software .

ns2:OtherTechnicalTerms a owl:Class ;
    rdfs:subClassOf ns2:UCOThing .

ns2:hasConsequence a owl:ObjectProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:range ns2:Consequence .

ns2:hasVendor a owl:DatatypeProperty ;
    rdfs:domain ns2:Product ;
    rdfs:range xsd:string .

ns2:usesAttacks a owl:ObjectProperty ;
    rdfs:domain ns2:Campaign ;
    rdfs:range ns2:Attack .

