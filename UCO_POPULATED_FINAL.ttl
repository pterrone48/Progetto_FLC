ns2:Means a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:Consequence ],
        ns2:MeansOrConsequence ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:onProperty ns1:behaviour ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( ns1:AttackPattern ns1:Exploit ns1:Malware ) ] ],
        ns2:TTP .

