@prefix ns1: <http://ffrdc.ebiquity.umbc.edu/ns/ontology/> .
@prefix ns2: <http://ffrdc.ebiquity.umbc.edu/ns/ontology/#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://capec.mitre.org/capec_v1#Indicator> a owl:Class ;
    rdfs:subClassOf ns2:UCOThing ;
    owl:equivalentClass ns1:Indicator .

<http://capec.mitre.org/capec_v1#Observable> a owl:Class ;
    rdfs:subClassOf ns2:UCOThing ;
    owl:equivalentClass <http://cybox.mitre.org/cybox_v1#Observable> .

<http://capec.mitre.org/capec_v1#Weakness> a owl:Class ;
    rdfs:subClassOf ns2:UCOThing ;
    owl:equivalentClass ns2:CWE .

ns2:AtError a owl:Class ;
    rdfs:subClassOf ns2:LogicExploit .

ns2:BoundaryCondition a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/Off-by-one_error"^^xsd:anyURI ;
    rdfs:subClassOf ns2:InputValidationError .

ns2:BufferOverFlow a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/Buffer_overflow"^^xsd:anyURI ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:DenialOfService ],
        ns2:Means .

ns2:ConfigurationError a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:DenialOfService ],
        ns2:Means .

ns2:DistributedCode a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:BotnetAttack ],
        ns2:MaliciousCodeExecution .

ns2:DomainExpert a owl:Class ;
    rdfs:subClassOf ns2:Source .

ns2:ExICMPEchoReq a owl:Class ;
    rdfs:subClassOf ns2:Means .

ns2:ExIPPacketSize a owl:Class ;
    rdfs:subClassOf ns2:Means .

ns2:ExceptionCondition a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/Exception_handling"^^xsd:anyURI ;
    rdfs:subClassOf ns2:LogicExploit .

ns2:ExcessForks a owl:Class ;
    rdfs:subClassOf ns2:DenialOfService .

ns2:IPFrag a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/IP_fragmentation_attacks"^^xsd:anyURI ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:DenialOfService ],
        ns2:Means .

ns2:IPv4Address a owl:Class ;
    rdfs:subClassOf ns2:IPAddress .

ns2:IPv6Address a owl:Class ;
    rdfs:subClassOf ns2:IPAddress .

ns2:MACAddress a owl:Class ;
    rdfs:subClassOf ns2:Address .

ns2:MalformedInput a owl:Class ;
    rdfs:seeAlso "http://sw.opencyc.org/concept/Mx4rwQShKJwpEbGdrcN5Y29ycA"^^xsd:anyURI ;
    rdfs:subClassOf ns2:InputValidationError .

ns2:MemoryConsumption a owl:Class ;
    rdfs:subClassOf ns2:DenialOfService .

ns2:ParisiticCode a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:LossOfIntegrity ],
        ns2:MaliciousCodeExecution .

ns2:PingOfDeath a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/Ping_of_death"^^xsd:anyURI ;
    rdfs:subClassOf ns2:DenialOfService .

ns2:PingScan a owl:Class ;
    rdfs:subClassOf ns2:Probe .

ns2:RSTProbe a owl:Class ;
    rdfs:subClassOf ns2:Probe .

ns2:RaceCondition a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/Race_condition"^^xsd:anyURI ;
    rdfs:subClassOf ns2:LogicExploit .

ns2:Rootkit a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/Rootkit"^^xsd:anyURI ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:DenialOfService ],
        [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:LossOfConf ],
        ns2:MaliciousCodeExecution .

ns2:SerialError a owl:Class ;
    rdfs:subClassOf ns2:LogicExploit .

ns2:SynFlood a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:NetFlood ],
        ns2:Means .

ns2:SynScan a owl:Class ;
    rdfs:subClassOf ns2:Probe .

ns2:SysCrash a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/Fatal_system_error"^^xsd:anyURI ;
    rdfs:subClassOf ns2:DenialOfService .

ns2:TCPConnect a owl:Class ;
    rdfs:subClassOf ns2:Probe .

ns2:TCPPortScan a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:DirectoryExposure ],
        ns2:Probe .

ns2:Time a owl:Class ;
    rdfs:subClassOf ns2:TriggeredCode .

ns2:Trojans a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:LossOfConf ],
        [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:RemoteAccess ],
        ns2:MaliciousCodeExecution .

ns2:UnauthRoot a owl:Class ;
    rdfs:subClassOf ns2:PrivilegeEsc .

ns2:UserEnumeration a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:PrivilegeEsc ],
        ns2:Means .

ns2:Virus a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/Computer_virus"^^xsd:anyURI ;
    rdfs:subClassOf ns2:SelfPropagatingCode .

ns2:WebBrowser a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/class/yago/WebBrowser"^^xsd:anyURI ;
    rdfs:subClassOf ns2:Software .

ns2:Worm a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/Computer_worm"^^xsd:anyURI ;
    rdfs:subClassOf ns2:SelfPropagatingCode .

ns2:affectsProduct a owl:ObjectProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:range ns2:Product .

ns2:anomolousDataOutFlow a owl:DatatypeProperty ;
    rdfs:domain ns2:NetworkState ;
    rdfs:range xsd:boolean .

ns2:associatedCampaigns a owl:ObjectProperty ;
    rdfs:domain ns2:Campaign ;
    rdfs:range ns2:Campaign .

ns2:chgGid a owl:DatatypeProperty ;
    rdfs:domain ns2:Process ;
    rdfs:range xsd:boolean .

ns2:chgPPid a owl:DatatypeProperty ;
    rdfs:domain ns2:Process ;
    rdfs:range xsd:boolean .

ns2:chgSUid a owl:DatatypeProperty ;
    rdfs:domain ns2:Process ;
    rdfs:range xsd:boolean .

ns2:chgUid a owl:DatatypeProperty ;
    rdfs:domain ns2:Process ;
    rdfs:range xsd:boolean .

ns2:commonConsequences a owl:DatatypeProperty ;
    rdfs:domain ns2:CWE .

ns2:connectedTo a owl:IrreflexiveProperty,
        owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:domain ns2:System ;
    rdfs:range ns2:System .

ns2:cweExtendedSummary a owl:DatatypeProperty ;
    rdfs:domain ns2:CWE .

ns2:cweID a owl:DatatypeProperty ;
    rdfs:domain ns2:CWE .

ns2:cweName a owl:DatatypeProperty ;
    rdfs:domain ns2:CWE .

ns2:cweSummary a owl:DatatypeProperty ;
    rdfs:domain ns2:CWE .

ns2:dataSize a owl:DatatypeProperty ;
    rdfs:domain ns2:Process ;
    rdfs:range xsd:integer .

ns2:description a owl:DatatypeProperty ;
    rdfs:domain ns2:CWE ;
    rdfs:range xsd:string .

ns2:exploitsVulnerability a owl:ObjectProperty ;
    rdfs:domain ns2:Means ;
    rdfs:range ns2:Vulnerability .

ns2:generated-on-datetime a owl:DatatypeProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:subPropertyOf ns2:hasSeverityScore .

ns2:hasAccessComplexity a owl:DatatypeProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf ns2:hasSeverityScore .

ns2:hasAccessVector a owl:DatatypeProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf ns2:hasSeverityScore .

ns2:hasAuthentication a owl:DatatypeProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:subPropertyOf ns2:hasSeverityScore .

ns2:hasAvailabilityImpact a owl:DatatypeProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:subPropertyOf ns2:hasSeverityScore .

ns2:hasCodeSize a owl:DatatypeProperty ;
    rdfs:domain ns2:Process ;
    rdfs:range xsd:integer .

ns2:hasConfidentialityImpact a owl:DatatypeProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:subPropertyOf ns2:hasSeverityScore .

ns2:hasDataSize a owl:DatatypeProperty ;
    rdfs:domain ns2:Process,
        ns2:UCOThing ;
    rdfs:range xsd:integer .

ns2:hasIPv4Address a owl:ObjectProperty ;
    rdfs:subPropertyOf ns2:hasIPAddress .

ns2:hasIPv6Address a owl:ObjectProperty ;
    rdfs:subPropertyOf ns2:hasIPAddress .

ns2:hasInformationSource a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

ns2:hasIntegrityImpact a owl:DatatypeProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:subPropertyOf ns2:hasSeverityScore .

ns2:hasLibSize a owl:DatatypeProperty ;
    rdfs:domain ns2:Process ;
    rdfs:range xsd:integer .

ns2:hasMACAddress a owl:DatatypeProperty,
        owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain ns2:System ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf owl:topObjectProperty .

ns2:hasMitigation a owl:ObjectProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:range ns2:CourseofAction .

ns2:hasProduct a owl:ObjectProperty ;
    rdfs:domain ns2:System ;
    rdfs:range ns2:Product .

ns2:hasSource a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:domain ns2:Attack,
        ns2:Vulnerability ;
    rdfs:range ns2:Source ;
    rdfs:subPropertyOf ns2:hasSeverityScore .

ns2:hasTerms a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain ns2:Web ;
    rdfs:range ns2:OtherTechnicalTerms .

ns2:hasVulnerability a owl:ObjectProperty ;
    rdfs:domain ns2:ExploitTarget,
        ns2:Means,
        ns2:Product ;
    rdfs:range ns2:Vulnerability .

ns2:hasVulnerabilityTerm a owl:DatatypeProperty ;
    rdfs:domain ns2:Web ;
    rdfs:range xsd:boolean .

ns2:isLaunchedBy a owl:ObjectProperty ;
    rdfs:domain ns2:Attack,
        ns2:Campaign ;
    rdfs:range ns2:Attacker .

ns2:isNew a owl:DatatypeProperty ;
    rdfs:domain ns2:Hardware,
        ns2:KernelModule ;
    rdfs:range xsd:boolean .

ns2:isResultOf a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:domain ns2:Consequence ;
    rdfs:range ns2:Means ;
    owl:inverseOf ns2:resultsIn .

ns2:isUnderAttack a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:domain ns2:System ;
    rdfs:range ns2:Attack,
        ns2:Consequence .

ns2:lastModifiedDateTime a owl:DatatypeProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:range xsd:dateTime .

ns2:newDestIP a owl:DatatypeProperty ;
    rdfs:domain ns2:NetworkState ;
    rdfs:range xsd:boolean .

ns2:newPortsOpened a owl:DatatypeProperty ;
    rdfs:domain ns2:NetworkState ;
    rdfs:range xsd:boolean .

ns2:numChildProcesses a owl:DatatypeProperty ;
    rdfs:domain ns2:Process ;
    rdfs:range xsd:integer .

ns2:numOpenFiles a owl:DatatypeProperty ;
    rdfs:domain ns2:Process ;
    rdfs:range xsd:integer .

ns2:numProcessesRunning a owl:DatatypeProperty ;
    rdfs:domain ns2:System ;
    rdfs:range xsd:integer .

ns2:opensPort a owl:DatatypeProperty ;
    rdfs:domain ns2:Process ;
    rdfs:range xsd:integer .

ns2:publishedDateTime a owl:DatatypeProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:range xsd:dateTime .

ns2:rstProbe a owl:Class ;
    rdfs:subClassOf ns2:Probe .

ns2:score a owl:DatatypeProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:range xsd:float ;
    rdfs:subPropertyOf ns2:hasSeverityScore .

ns2:selfDist a owl:DatatypeProperty ;
    rdfs:domain ns2:Process ;
    rdfs:range xsd:integer .

ns2:showsInfectionSigns a owl:DatatypeProperty ;
    rdfs:domain ns2:Process ;
    rdfs:range xsd:boolean .

ns2:summary a owl:DatatypeProperty ;
    rdfs:domain ns2:Vulnerability ;
    rdfs:range xsd:string .

ns2:timeOfIntroduction a owl:DatatypeProperty ;
    rdfs:domain ns2:CWE ;
    rdfs:range xsd:dateTime .

