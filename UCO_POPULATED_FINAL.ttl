ns1:DDoS a owl:Class ;
    rdfs:comment """Distributed denial-of-service attacks are a type of denial-of-service attack (DoS attack), a category that includes all cyberattacks that slow or stop applications or services. DDoS attacks are unique in that they send attack traffic from multiple sources all at once—potentially making then harder to recognize and defend against—which puts the “distributed” into “distributed denial-of-service.”

Source: https://www.ibm.com/think/topics/ddos"""^^xsd:string ;
    rdfs:subClassOf ns2:BotnetAttack,
        ns2:DenialOfService .

