ns1:Phishing a owl:Class ;
    rdfs:comment """Phishing is a type of cyberattack that uses fraudulent emails, text messages, phone calls or websites to trick people into sharing sensitive data, downloading malware or otherwise exposing themselves to cybercrime.

Source: https://www.ibm.com/think/topics/phishing"""^^xsd:string ;
    rdfs:subClassOf ns2:Consequence .

