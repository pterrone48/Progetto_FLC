<http://stix.mitre.org/STIX#KillChainPhase> a owl:Class ;
    rdfs:subClassOf ns2:UCOThing .

ns2:DirectoryExposure a owl:Class ;
    rdfs:subClassOf ns2:LossOfConf .

ns2:InputValidationError a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:LossOfConf ],
        ns2:Means .

ns2:KernelModule a owl:Class ;
    rdfs:seeAlso "http://dbpedia.org/resource/Loadable_kernel_module"^^xsd:anyURI ;
    rdfs:subClassOf ns2:Software .

ns2:MeansOrConsequence a owl:Class ;
    rdfs:subClassOf ns2:UCOThing .

ns2:SelfPropagatingCode a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:LossOfConf ],
        ns2:MaliciousCodeExecution .

ns2:TTP a owl:Class ;
    rdfs:comment """Tactics, Techniques and Procedures (TTP) are representations of the behavior or modus operandi of cyber adversaries.

Source: https://stix.mitre.org/about/documents/STIX_Whitepaper_v1.1.pdf"""^^xsd:string ;
    rdfs:subClassOf ns2:UCOThing .

ns2:TriggeredCode a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:LossOfConf ],
        [ a owl:Restriction ;
            owl:onProperty ns2:resultsIn ;
            owl:someValuesFrom ns2:LossOfIntegrity ],
        ns2:MaliciousCodeExecution .

ns2:hasIPAddress a owl:ObjectProperty ;
    rdfs:domain ns2:System ;
    rdfs:range ns2:IPAddress ;
    rdfs:subPropertyOf owl:topObjectProperty .

ns2:hasMeans a owl:ObjectProperty ;
    rdfs:domain ns2:Attack,
        ns2:Campaign,
        ns2:Vulnerability,
        ns1:Indicator ;
    rdfs:range ns2:Means .

ns1:AttackEmail a owl:Class ;
    rdfs:label "attack email"^^xsd:string ;
    rdfs:subClassOf ns2:BotnetAttack .

ns1:AttackInformation a owl:Class ;
    rdfs:label "attack information"^^xsd:string ;
    rdfs:subClassOf ns1:AttackPattern .

ns1:AttackPhishing a owl:Class ;
    rdfs:label "attack phishing"^^xsd:string ;
    rdfs:subClassOf ns2:BotnetAttack .

ns1:AttackSchool a owl:Class ;
    rdfs:label "attack school"^^xsd:string ;
    rdfs:subClassOf ns1:AttackPattern .

