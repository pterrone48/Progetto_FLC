    rdfs:domain ns2:Attacker,
        ns2:Campaign ;
    rdfs:range ns2:Campaign .

ns1:hasAttacker a owl:ObjectProperty ;
    rdfs:domain ns2:Attack ;
    rdfs:range ns2:Attacker ;
    rdfs:subPropertyOf ns2:hasMeans .

ns1:hasCOAType a owl:ObjectProperty ;
    rdfs:domain ns2:CourseofAction .

ns1:hasCVE_ID a owl:ObjectProperty ;
    rdfs:domain ns2:Vulnerability ;
