ns1:hasActor a owl:DatatypeProperty ;
    rdfs:domain ns2:Attack,
        ns2:UCOThing ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf owl:topDataProperty .

ns1:hasActorCountry a owl:DatatypeProperty ;
    rdfs:domain ns2:Attacker,
        ns2:UCOThing ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf owl:topDataProperty .

