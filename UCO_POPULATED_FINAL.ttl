    rdfs:domain ns2:Attacker,
        ns2:UCOThing ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf owl:topDataProperty .

ns1:hasAffectedSoftware a owl:ObjectProperty ;
    rdfs:comment "The Affected_Software field captures the list of platforms and software that are affected by this vulnerability. It is implemented through the CybOX Observables, the suggested CybOX objects to use are the Product Object, the Device Object, the System Object, and the Code Object."^^xsd:string ;
    rdfs:seeAlso "http://stixproject.github.io/data-model/1.2/et/VulnerabilityType/"^^xsd:string ;
    owl:equivalentProperty ns1:hasObservable .

