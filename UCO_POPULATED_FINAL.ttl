ns1:Network a owl:Class ;
    rdfs:comment """A network is defined as the connection of at least two computer systems, either by a cable or a wireless connection. The simplest network is a combination of two computers connected by a cable. This type of network is called a peer-to-peer network. There is no hierarchy in this network; both participants have equal privileges. Each computer has access to the data of the other device and can share resources such as disk space, applications or peripheral devices (printers, etc.).

Source: https://www.ionos.com/digitalguide/server/know-how/what-is-a-network/"""^^xsd:string ;
    rdfs:subClassOf ns2:UCOThing .

ns1:Washington_D_C a owl:NamedIndividual,
        owl:Thing .

ns1:Account a owl:Class ;
    rdfs:comment ""^^xsd:string,
        """An online account is a private, secure account that you create with a business or
website to access and save personal information specific to you and that
website/business. An online account is created with your personal information,
including a username and password, so you can access it later. 

Source: https://www.browncountylibrary.org/wp-content/uploads/2022/01/JobGuide_IntrotoOnlineAccounts.pdf"""^^xsd:string ;
    rdfs:subClassOf ns2:UCOThing .

